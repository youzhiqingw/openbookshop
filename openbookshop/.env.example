# ============================================================
# OpenBookShop 环境变量配置示例
# 复制本文件为 .env 后修改对应值
# cp .env.example .env
# ============================================================

# ── Django 核心配置 ──────────────────────────────────────────
# 生产环境必须修改为随机长字符串，可用以下命令生成：
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=请替换为随机密钥（运行 python -c "import secrets; print(secrets.token_urlsafe(50))" 生成）

# 生产环境请设为 False
DJANGO_DEBUG=False

# 允许访问的主机名，多个用英文逗号分隔
ALLOWED_HOSTS=localhost,127.0.0.1

# 允许跨域的前端地址，多个用英文逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── MySQL 数据库配置（使用 Docker 时填写）────────────────────
MYSQL_ROOT_PASSWORD=bookshop123
MYSQL_DATABASE=bookstore
MYSQL_USER=bookshop
MYSQL_PASSWORD=bookshop123
